# Ignore build artifacts
*.o
*.a
*.bin

# Ignore generated files and folders
obj/
lib/
build/
SceneTest/

# Ignore example build outputs
docs/examples/*/main.o

# Allow example models
!docs/examples/PathTracer/SponzaScene/**/*.bin
!docs/examples/ObjVoxelizer/testScene/**/*.bin

# Ignore VS Code config files
.vscode/

# Ignore clangd cache
.cache/



